/* pages/index/index.wxss */
.page-container {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 140rpx;
}

/* Hero区域 */
.hero-section {
  position: relative;
  padding: 60rpx 40rpx 50rpx;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(145deg, #1A3A5C, #2B5C8A, #3A7BC8);
  z-index: 0;
}

.hero-bg::after {
  content: '';
  position: absolute;
  bottom: -2rpx;
  left: 0;
  right: 0;
  height: 40rpx;
  background: #F5F7FA;
  border-radius: 40rpx 40rpx 0 0;
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.hero-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.hero-title {
  font-size: 56rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
  margin-bottom: 28rpx;
  padding: 0 20rpx;
}

.hero-tags {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.hero-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  color: #ffffff;
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

/* 功能入口 */
.action-section {
  padding: 20rpx 30rpx;
}

.start-btn {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(43, 92, 138, 0.12);
  border: 2rpx solid #E0ECF7;
  line-height: normal;
  text-align: left;
}

.start-btn::after {
  border: none;
}

.start-btn-icon {
  font-size: 52rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.start-btn-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.start-btn-main {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 6rpx;
  word-break: break-all;
}

.start-btn-desc {
  font-size: 24rpx;
  color: #7A8EA0;
  margin-bottom: 16rpx;
}

.start-btn-sub {
 

  font-size: 28rpx;
  color: #ffffff;
  background: #2B5C8A;
  padding: 16rpx 16rpx 32rpx 32rpx;
  border-radius: 40rpx;
  display: inline-block;
  text-align: center;
  width: 130rpx;
  margin-top: 10rpx;
}

.start-btn-arrow {
  font-size: 40rpx;
  color: #2B5C8A;
  font-weight: 300;
  flex-shrink: 0;
}

/* 特点区域 */
.features-section {
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.feature-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.feature-icon {
  font-size: 44rpx;
  margin-bottom: 14rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A3A5C;
  margin-bottom: 10rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #7A8EA0;
  line-height: 1.5;
}

/* 法规区域 */
.law-section {
  padding: 10rpx 30rpx 20rpx;
}

.law-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.law-item {
  display: flex;
  align-items: flex-start;
  padding: 14rpx 0;
  font-size: 25rpx;
  color: #4A6275;
  line-height: 1.5;
}

.law-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #2B5C8A;
  margin-top: 12rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

/* 免责声明 */
.disclaimer {
  margin: 20rpx 30rpx;
  padding: 24rpx 28rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.disclaimer-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #8D6E00;
  line-height: 1.6;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 30rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #A0B0C0;
  display: block;
  margin-bottom: 6rpx;
}

.footer-version {
  font-size: 20rpx;
  color: #C0D0E0;
}
