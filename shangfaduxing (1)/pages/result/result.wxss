/* pages/result/result.wxss */
.result-page {
  min-height: 100vh;
  background: #F0F3F7;
  padding-bottom: 40rpx;
}

/* 顶部状态 */
.result-header {
  padding: 50rpx 40rpx 40rpx;
  text-align: center;
}

.header-success {
  background: linear-gradient(145deg, #1A3A5C, #2B5C8A);
}

.header-fail {
  background: linear-gradient(145deg, #8B4513, #BF6A30);
}

.header-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.header-detail {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

/* 通用section */
.section {
  padding: 0 24rpx;
  margin-top: 24rpx;
}

.section-title-bar {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A2A3A;
}

.section-subtitle {
  font-size: 24rpx;
  color: #7A8EA0;
  margin-left: 8rpx;
}

/* 最终裁判结论 */
.final-result-card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border-left: 8rpx solid #2B5C8A;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.final-item-label {
  font-size: 24rpx;
  color: #7A8EA0;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.final-item-result {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.final-item-detail {
  font-size: 25rpx;
  color: #4A6275;
  line-height: 1.6;
}

/* 推理路径 */
.path-card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.path-header {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
}

.path-index {
  width: 44rpx;
  height: 44rpx;
  background: #2B5C8A;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.path-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A2A3A;
}

.path-conditions {
  background: #F8FAFB;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
}

.path-calc {
  font-size: 23rpx;
  color: #7A8EA0;
  margin-bottom: 10rpx;
}

.calc-tag {
  display: inline;
  padding: 2rpx 12rpx;
  background: #EBF3FE;
  color: #2B5C8A;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.condition-list {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.condition-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.cond-check {
  color: #4CAF50;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.cond-text {
  font-size: 24rpx;
  color: #3A5060;
  line-height: 1.4;
}

/* 法律适用分析（结论卡片） */
.conclusion-card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.conclusion-type {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.type-badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.type-badge.property_nature {
  background: #EBF3FE;
  color: #2B5C8A;
}

.type-badge.split_rule {
  background: #E8F5E9;
  color: #2E7D32;
}

.type-badge.split_adjustment {
  background: #FFF3E0;
  color: #E65100;
}

.level-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.level-critical {
  background: #FEECEC;
  color: #C62828;
}

.level-important {
  background: #E3F2FD;
  color: #1565C0;
}

.level-warning {
  background: #FFF8E1;
  color: #F57F17;
}

.level-info {
  background: #F3F4F6;
  color: #6B7280;
}

.conclusion-result {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A2A3A;
  margin-bottom: 10rpx;
  line-height: 1.4;
}

.conclusion-reason {
  font-size: 25rpx;
  color: #4A6275;
  line-height: 1.6;
}

/* 法条卡片 */
.law-card {
  background: #ffffff;
  border-radius: 14rpx;
  padding: 24rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.law-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.law-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.law-article {
  display: inline-block;
  padding: 4rpx 14rpx;
  background: #2B5C8A;
  color: #ffffff;
  font-size: 22rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.law-summary {
  font-size: 24rpx;
  color: #7A8EA0;
  margin-bottom: 12rpx;
}

.law-text-toggle {
  font-size: 24rpx;
  color: #2B5C8A;
  font-weight: 500;
  padding: 8rpx 0;
}

.law-full-text {
  font-size: 24rpx;
  color: #4A6275;
  line-height: 1.7;
  padding: 16rpx 20rpx;
  background: #F8FAFB;
  border-radius: 10rpx;
  margin-top: 8rpx;
  border-left: 4rpx solid #2B5C8A;
}

/* 免责声明 */
.disclaimer-section {
  padding: 24rpx;
}

.disclaimer-box {
  background: #FFF8E1;
  border-radius: 12rpx;
  padding: 24rpx;
  border: 1rpx solid #FFE082;
}

.disclaimer-title {
  display: block;
  font-size: 26rpx;
  font-weight: 700;
  color: #8D6E00;
  margin-bottom: 10rpx;
}

.disclaimer-content {
  font-size: 23rpx;
  color: #8D6E00;
  line-height: 1.7;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 24rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.action-btn-restart {
  background: linear-gradient(135deg, #2B5C8A, #3A7BC8);
  color: #ffffff;
}

.action-btn-dissatisfied {
  background: #FF6B35;
  color: #ffffff;
}

.action-btn-home {
  background: #F0F4F8;
  color: #4A6275;
  border: 1rpx solid #D8E2EC;
}
