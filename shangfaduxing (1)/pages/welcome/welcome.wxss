/* pages/welcome/welcome.wxss */
.welcome-container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.welcome-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.welcome-content {
  position: absolute;
  top: 25%;
  left: 0;
  right: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.welcome-title {
  font-family: "KaiTi", "STKaiti", serif;
 
  font-size: 120rpx;
  font-weight: 700;
  color: #58351B;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
  text-shadow: 0.6rpx 0 0 currentColor;

}

.welcome-subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color:#2B5C8A;
  margin-bottom: 80rpx;
  letter-spacing: 4rpx;
}

.welcome-entry {
  padding: 24rpx 80rpx;
  background: #2B5C8A;
  border: 2rpx solid #2B5C8A;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
}
