/* pages/evidence/evidence.wxss */
.evidence-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 提示信息 */
.tips-section {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #E3F2FD;
  margin: 20rpx;
  border-radius: 12rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #1565C0;
}

/* 证据区块 */
.evidence-section {
  padding: 0 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.fact-item {
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.fact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #FFF3E0;
  border-bottom: 1rpx solid #FFE0B2;
}

.fact-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #E65100;
}

.fact-status {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-unproved {
  background: #FF9800;
  color: #ffffff;
}

.evidence-list {
  padding: 24rpx;
}

.evidence-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A3A5C;
  margin-bottom: 12rpx;
}

.evidence-items {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.evidence-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #E3F2FD;
  color: #1565C0;
  border-radius: 20rpx;
}

.evidence-desc {
  background: #F8FAFB;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.desc-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #2B5C8A;
  margin-bottom: 8rpx;
}

.desc-content {
  font-size: 24rpx;
  color: #4A6275;
  line-height: 1.6;
}

/* 是否有证据 */
.has-evidence {
  margin-top: 16rpx;
}

.has-label {
  font-size: 26rpx;
  color: #1A3A5C;
  margin-bottom: 12rpx;
}

.has-options {
  display: flex;
  gap: 20rpx;
}

.has-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #7A8EA0;
  background: #F0F4F8;
  border-radius: 10rpx;
  border: 2rpx solid transparent;
}

.has-option.selected {
  color: #2B5C8A;
  background: #E3F2FD;
  border-color: #2B5C8A;
}

/* 其他证据 */
.other-evidence-section {
  padding: 0 20rpx;
  margin-top: 20rpx;
}

.other-input {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.other-textarea {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #1A3A5C;
  line-height: 1.6;
}

.other-textarea::placeholder {
  color: #A0B0C0;
}

/* 人工帮助 */
.human-help-section {
  padding: 20rpx;
}

.help-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.help-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.help-info {
  flex: 1;
}

.help-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
  margin-bottom: 8rpx;
}

.help-desc {
  font-size: 24rpx;
  color: #7A8EA0;
}

.help-arrow {
  font-size: 40rpx;
  color: #C0D0E0;
}

/* 操作按钮 */
.action-section {
  padding: 30rpx 20rpx;
}

.export-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2B5C8A, #3A7BC8);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  padding: 28rpx 0;
  border-radius: 50rpx;
  border: none;
  margin-bottom: 20rpx;
}

.export-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

.back-btn {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #2B5C8A;
}