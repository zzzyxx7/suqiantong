/* pages/my/my.wxss */
.my-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 120rpx;
}

/* Tab 容器 */
.tab-container {
  display: flex;
  background: #ffffff;
  border-bottom: 2rpx solid #E8ECF2;
  position: sticky;
  top: 0;
  z-index: 100;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  color: #7A8EA0;
  position: relative;
}

.tab-item.active {
  color: #2B5C8A;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #2B5C8A;
  border-radius: 3rpx;
}

/* Tab 内容区 */
.tab-content {
  padding: 30rpx;
}

/* 服务介绍 */
.service-intro {
  background: linear-gradient(135deg, #2B5C8A, #3A7BC8);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  text-align: center;
}

.intro-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.intro-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.intro-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.6;
}

/* 流程区域 */
.process-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 24rpx;
  padding-left: 4rpx;
}

.process-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.process-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F2F5;
}

.process-item:last-child {
  border-bottom: none;
}

.process-num {
  width: 48rpx;
  height: 48rpx;
  background: #2B5C8A;
  color: #ffffff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.process-content {
  flex: 1;
}

.process-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
  margin-bottom: 8rpx;
}

.process-desc {
  font-size: 24rpx;
  color: #7A8EA0;
}

/* 按钮组 */
.action-btn-group {
  margin-bottom: 30rpx;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2B5C8A;
  color: #ffffff;
  border-radius: 50rpx;
  padding: 28rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.submit-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 状态区域 */
.status-section {
  margin-bottom: 30rpx;
}

.status-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.status-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F2F5;
}

.status-item:last-child {
  border-bottom: none;
}

.status-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.status-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.status-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.status-tag.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.status-tag.processing {
  background: #E3F2FD;
  color: #2196F3;
}

.status-tag.completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-desc {
  font-size: 26rpx;
  color: #7A8EA0;
  margin-bottom: 12rpx;
}

.status-time {
  font-size: 22rpx;
  color: #A0B0C0;
}

.empty-status, .empty-case {
  text-align: center;
  color: #A0B0C0;
  font-size: 26rpx;
  padding: 40rpx 0;
}

/* 案件区域 */
.cases-section {
  margin-bottom: 30rpx;
}

.cases-list {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.case-item {
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F2F5;
}

.case-item:last-child {
  border-bottom: none;
}

.case-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.case-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A3A5C;
}

.case-status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.case-status.completed {
  background: #E8F5E9;
  color: #4CAF50;
}

.case-status.processing {
  background: #E3F2FD;
  color: #2196F3;
}

.case-status.pending {
  background: #FFF3E0;
  color: #FF9800;
}

.case-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.case-type {
  font-size: 26rpx;
  color: #7A8EA0;
}

.case-date {
  font-size: 24rpx;
  color: #A0B0C0;
}

.case-actions {
  display: flex;
  gap: 24rpx;
}

.action-link {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #2B5C8A;
  padding: 12rpx 20rpx;
  background: #F0F5FA;
  border-radius: 30rpx;
}

.link-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 30rpx;
}

.settings-list {
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  overflow: hidden;
}

.settings-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0F2F5;
}

.settings-item:last-child {
  border-bottom: none;
}

.settings-left {
  display: flex;
  align-items: center;
}

.settings-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.settings-label {
  font-size: 30rpx;
  color: #1A3A5C;
}

.settings-arrow {
  font-size: 36rpx;
  color: #C0D0E0;
}