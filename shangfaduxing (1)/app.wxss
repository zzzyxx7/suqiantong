/* app.wxss - 全局样式 */
page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 主色按钮 */
.btn-primary {
  background: linear-gradient(135deg, #2B5C8A, #3A7BC8);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  opacity: 0.85;
}

/* 次要按钮 */
.btn-secondary {
  background: #ffffff;
  color: #2B5C8A;
  border: 2rpx solid #2B5C8A;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 500;
  text-align: center;
  width: 100%;
}

.btn-secondary::after {
  border: none;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #E8ECF0;
  margin: 24rpx 0;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.tag-blue {
  background: #EBF3FE;
  color: #2B5C8A;
}

.tag-green {
  background: #E8F8EE;
  color: #1A7F37;
}

.tag-orange {
  background: #FFF3E0;
  color: #E65100;
}

.tag-red {
  background: #FEECEC;
  color: #C62828;
}
