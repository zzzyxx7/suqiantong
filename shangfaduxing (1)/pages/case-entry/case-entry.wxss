.case-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top, rgba(82, 148, 219, 0.18), transparent 42%),
    linear-gradient(180deg, #eaf3fb 0%, #f6f9fc 38%, #f8fbff 100%);
  padding-bottom: 80rpx;
}

.hero-section {
  position: relative;
  overflow: hidden;
  padding: 84rpx 48rpx 170rpx;
  background: linear-gradient(180deg, #214d7a 0%, #2b5c8a 58%, #3c82c3 100%);
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at 50% 35%, rgba(255, 255, 255, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0));
}

.hero-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.hero-icon {
  font-size: 66rpx;
  margin-bottom: 26rpx;
}

.hero-title {
  font-size: 50rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 4rpx;
  margin-bottom: 18rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.86);
  padding: 0 18rpx;
}

.hero-tags {
  margin-top: 32rpx;
  display: flex;
  justify-content: center;
  gap: 18rpx;
  flex-wrap: wrap;
}

.hero-tag {
  padding: 10rpx 26rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.34);
  background: rgba(255, 255, 255, 0.14);
  color: #f5fbff;
  font-size: 24rpx;
}

.content-card {
  position: relative;
  z-index: 2;
  margin-top: -86rpx;
  background: rgba(255, 255, 255, 0.96);
  border-radius: 42rpx 42rpx 0 0;
  padding: 42rpx 18rpx 40rpx;
  box-shadow: 0 -10rpx 30rpx rgba(33, 77, 122, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #22384f;
  margin: 12rpx 0 24rpx;
  padding: 0 10rpx;
}

.case-input {
  width: 100%;
  min-height: 150rpx;
  box-sizing: border-box;
  padding: 26rpx 24rpx;
  border-radius: 18rpx;
  background: #ffffff;
  /* 重点修改：加粗边框+加深颜色，让边框更醒目 */
  border: 3rpx solid #9ab0c4; 
  /* 可选：增加轻微阴影，强化边框层次感 */
  box-shadow: 0 0 0 1rpx rgba(154, 176, 196, 0.2);
  color: #26415d;
  font-size: 29rpx;
  line-height: 1.6;
  /* 可选：聚焦时边框更突出，提升交互体验 */
  outline: none;
}
/* 输入框聚焦/点击时的样式（可选，增强体验） */
.case-input:focus {
  border-color: #2b5c8a; /* 聚焦时边框变成主题色，更醒目 */
  box-shadow: 0 0 0 4rpx rgba(43, 92, 138, 0.15); /* 轻微外发光 */
}

.submit-btn {
  width: 240rpx; /* 缩短了，原来304太长 → 改成240 */
  height: 80rpx; /* 稍微降低高度，更精致 */
  line-height: 80rpx; /* 和高度一致，保证文字垂直居中 */
  padding: 0 40rpx; /* 内边距让文字不贴边 */
  margin: 40rpx auto 50rpx; /* 上下间距微调 */
  border-radius: 999rpx;
  border: none;
  color: #ffffff;
  font-size: 32rpx; /* 字体稍微缩小一点更协调 */
  font-weight: 700;
  background: linear-gradient(135deg, #245482 0%, #2f6ea7 100%);
  box-shadow: 0 16rpx 32rpx rgba(43, 92, 138, 0.22);
  text-align: center;
  display: block;
}

.submit-btn::after {
  border: none;
}

.reasons-title {
  margin-top: 10rpx;
}

.reason-list {
  /* 第一幅图卡片样式：圆角 + 浅边框 + 干净阴影 */
  overflow: hidden;
  border-radius: 24rpx;
  background: #ffffff;
  border: 10rpx solid #e5e9f0; /* 外边框（第一幅图的关键） */
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05); /* 柔和阴影 */
}

.reason-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 26rpx;
  border-bottom: 10rpx solid #edf2f8; /* 内部分割线 */
}

.reason-item:last-child {
  border-bottom: none;
}

.reason-text {
  font-size: 31rpx;
  color: #37536d;
}

.reason-arrow {
  font-size: 42rpx;
  line-height: 1;
  color: #9ab0c4;
}