/* pages/other-results/other-results.wxss */
.other-results-page {
  min-height: 100vh;
  background: #F5F7FA;
  padding-bottom: 40rpx;
}

/* 当前预测结果 */
.current-result {
  background: linear-gradient(135deg, #1A3A5C, #2B5C8A);
  padding: 40rpx 30rpx;
}

.current-title {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 20rpx;
}

.current-content {
  display: flex;
  align-items: flex-start;
}

.current-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.current-info {
  flex: 1;
}

.current-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 8rpx;
}

.current-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 10rpx;
}

.current-detail {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

/* 提示信息 */
.tips-section {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #E3F2FD;
  margin: 20rpx;
  border-radius: 12rpx;
}

.tips-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 26rpx;
  color: #1565C0;
}

/* 结果列表 */
.results-list {
  padding: 0 20rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.result-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A3A5C;
}

.difficulty-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.difficulty-low {
  background: #E8F5E9;
  color: #2E7D32;
}

.difficulty-medium {
  background: #FFF3E0;
  color: #E65100;
}

.difficulty-high {
  background: #FFEBEE;
  color: #C62828;
}

.result-desc {
  font-size: 26rpx;
  color: #4A6275;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.result-basis {
  background: #F8FAFB;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.basis-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #2B5C8A;
  margin-bottom: 8rpx;
}

.basis-content {
  font-size: 24rpx;
  color: #4A6275;
  line-height: 1.5;
}

.result-actions {
  display: flex;
  justify-content: flex-end;
}

.select-btn {
  background: linear-gradient(135deg, #2B5C8A, #3A7BC8);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  border: none;
}

.select-btn::after {
  border: none;
}

/* 返回按钮 */
.back-section {
  padding: 20rpx;
}

.back-btn {
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #2B5C8A;
}